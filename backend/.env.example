CONNECTION_STRING = mongodb+srv://<user>:<password>@<cluster>.mongodb.net/Nexa?retryWrites=true&w=majority

JWT_SECRET = JWTSECRET
JWT_LIFETIME = 30d

PORT = 5000
GOOGLE_CLIENT_ID = <your_google_oauth_client_id>

# OpenCodeZen API (Nemotron 3 Ultra Free)
OPENCODEZEN_API_KEY = <your_opencodezen_api_key>
OPENCODEZEN_BASE_URL = https://opencode.ai/zen/v1
OPENCODEZEN_MODEL = nemotron-3-ultra-free

UNSPLASH_ACCESS_KEY = <your_unsplash_access_key>
UNSPLASH_SECRET_KEY = <your_unsplash_secret_key>
PIXABAY_API_KEY = <your_pixabay_api_key>
